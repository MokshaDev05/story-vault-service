# Story Vault Service — environment variable reference
# Copy this file to application-local.properties and fill in real values,
# or export these as environment variables before starting the application.

# ── JWT ───────────────────────────────────────────────────────────────────────
# Required. The application will fail to start if this is not set.
# Generate one with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# Overrides the defaults in application.properties when running outside Docker.
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5434/storyvaultdb
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=postgres
